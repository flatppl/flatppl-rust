// Built-in base distribution catalogue (spec §08).
// One Builtin row per distribution; modules: [] this phase.
// Faithfulness test in crates/infer/src/ops.rs proves this table reproduces
// the legacy ops.rs distribution_domain / distribution_support rules exactly.
Catalogue(
    base: [
        // ---- Continuous univariate, domain ⊆ ℝ ----
        Builtin(name: "Normal",            sig: Distribution(domain: Scalar(Real), support: Reals,         mass: Normalized, params: ["mu", "sigma"])),
        Builtin(name: "GeneralizedNormal", sig: Distribution(domain: Scalar(Real), support: Reals,         mass: Normalized, params: ["mean", "alpha", "beta"])),
        Builtin(name: "Cauchy",            sig: Distribution(domain: Scalar(Real), support: Reals,         mass: Normalized, params: ["location", "scale"])),
        Builtin(name: "StudentT",          sig: Distribution(domain: Scalar(Real), support: Reals,         mass: Normalized, params: ["nu"])),
        Builtin(name: "Logistic",          sig: Distribution(domain: Scalar(Real), support: Reals,         mass: Normalized, params: ["mu", "s"])),
        Builtin(name: "VonMises",          sig: Distribution(domain: Scalar(Real), support: Reals,         mass: Normalized, params: ["mu", "kappa"])),
        Builtin(name: "Laplace",           sig: Distribution(domain: Scalar(Real), support: Reals,         mass: Normalized, params: ["location", "scale"])),
        Builtin(name: "LogNormal",         sig: Distribution(domain: Scalar(Real), support: PosReals,      mass: Normalized, params: ["mu", "sigma"])),
        // Gamma/ChiSquared: spec §08 — support `nonnegreals`, not `posreals`.
        // The density is nonzero at x=0 whenever shape <= 1 (Exponential IS
        // Gamma(1, rate); ChiSquared(k) = Gamma(k/2, 1/2), so ChiSquared(2) =
        // Exponential(1/2)) — scipy oracle: Gamma(1,1)@0=1.0, ChiSquared(2)@0=0.5.
        Builtin(name: "Gamma",             sig: Distribution(domain: Scalar(Real), support: NonNegReals,   mass: Normalized, params: ["shape", "rate"])),
        Builtin(name: "InverseGamma",      sig: Distribution(domain: Scalar(Real), support: PosReals,      mass: Normalized, params: ["shape", "scale"])),
        Builtin(name: "ChiSquared",        sig: Distribution(domain: Scalar(Real), support: NonNegReals,   mass: Normalized, params: ["k"])),
        Builtin(name: "Exponential",       sig: Distribution(domain: Scalar(Real), support: NonNegReals,   mass: Normalized, params: ["rate"])),
        Builtin(name: "Weibull",           sig: Distribution(domain: Scalar(Real), support: NonNegReals,   mass: Normalized, params: ["shape", "scale"])),
        Builtin(name: "Beta",              sig: Distribution(domain: Scalar(Real), support: UnitInterval,  mass: Normalized, params: ["alpha", "beta"])),
        // Pareto: spec §08 — domain reals, support posreals (x >= x_m > 0).
        // Legacy ops.rs distribution_domain does not list Pareto (falls through
        // to %deferred); this row brings the catalogue into spec compliance.
        Builtin(name: "Pareto",            sig: Distribution(domain: Scalar(Real), support: PosReals,      mass: Normalized, params: ["shape", "scale"])),
        // Uniform(support): spec §08 — domain is `reals`, support is the set
        // expression passed as argument (structural, not a fixed tag).
        // SupportTag::Structural signals to Task-4 dispatch that the support
        // MUST be kept on the code path (ops.rs set_expr_valueset); the static
        // approximation is Unknown (the catalogue row is domain-only for Uniform).
        Builtin(name: "Uniform",           sig: Distribution(domain: Scalar(Real), support: Structural,    mass: Normalized, params: ["support"])),

        // ---- Discrete univariate ----
        // Bernoulli: spec §08 "Domain/Support: integers/booleans" — density is
        // w.r.t. Counting(integers); the variate is integer-typed, support is
        // {0,1} = booleans. Legacy ops.rs returns Scalar(Boolean) for domain
        // (a legacy bug: domain should be integers per spec).
        Builtin(name: "Bernoulli",         sig: Distribution(domain: Scalar(Integer), support: Booleans,       mass: Normalized, params: ["p"])),
        // Categorical/Categorical0/Binomial: spec §08 supports are param-bounded
        // integer intervals, but ValueSet::Interval takes only static literal
        // bounds — a parameter-dependent integer-bounded set is inexpressible, so
        // the sound named-set superset is used and flagged degraded (honest-degrade
        // policy). Support value is unchanged from legacy ops.rs.
        Builtin(name: "Categorical",       sig: Distribution(domain: Scalar(Integer), support: PosIntegers,    mass: Normalized, params: ["p"]),
            degraded: Some("spec §08 support is interval(1, n); type system has no parameter-dependent integer-bounded ValueSet → PosIntegers (sound superset)")),
        Builtin(name: "Categorical0",      sig: Distribution(domain: Scalar(Integer), support: NonNegIntegers, mass: Normalized, params: ["p"]),
            degraded: Some("spec §08 support is interval(0, n-1); type system has no parameter-dependent integer-bounded ValueSet → NonNegIntegers (sound superset)")),
        Builtin(name: "Binomial",          sig: Distribution(domain: Scalar(Integer), support: NonNegIntegers, mass: Normalized, params: ["n", "p"]),
            degraded: Some("spec §08 support is interval(0, n); type system has no parameter-dependent integer-bounded ValueSet → NonNegIntegers (sound superset)")),
        Builtin(name: "Geometric",         sig: Distribution(domain: Scalar(Integer), support: NonNegIntegers, mass: Normalized, params: ["p"])),
        Builtin(name: "NegativeBinomial",  sig: Distribution(domain: Scalar(Integer), support: NonNegIntegers, mass: Normalized, params: ["alpha", "beta"])),
        Builtin(name: "NegativeBinomial2", sig: Distribution(domain: Scalar(Integer), support: NonNegIntegers, mass: Normalized, params: ["mu", "psi"])),
        Builtin(name: "Poisson",           sig: Distribution(domain: Scalar(Integer), support: NonNegIntegers, mass: Normalized, params: ["rate"])),

        // ---- Multivariate ----
        // MvNormal: domain ℝ^n, support CartPow(Reals, n) where n = length(mu).
        Builtin(name: "MvNormal",    sig: Distribution(domain: VectorFromParam(elem: Real,    param: "mu"),    support: CartPowReals,          mass: Normalized, params: ["mu", "cov"])),
        // Dirichlet: domain Δ^n (standard simplex), support StdSimplex(n) where n = length(alpha).
        Builtin(name: "Dirichlet",   sig: Distribution(domain: VectorFromParam(elem: Real,    param: "alpha"), support: StdSimplex,            mass: Normalized, params: ["alpha"])),
        // Multinomial: domain ℕ^n, support CartPow(NonNegIntegers, n) where n = length(p).
        Builtin(name: "Multinomial", sig: Distribution(domain: VectorFromParam(elem: Integer, param: "p"),     support: CartPowNonNegIntegers, mass: Normalized, params: ["n", "p"])),

        // ---- Matrix distributions ----
        // Legacy ops.rs does not enumerate these in distribution_support (falls
        // through to Unknown). Domain is always a dynamic real matrix.
        Builtin(name: "Wishart",        sig: Distribution(domain: DynMatrix, support: Unknown, mass: Normalized, params: ["nu", "scale"])),
        Builtin(name: "InverseWishart", sig: Distribution(domain: DynMatrix, support: Unknown, mass: Normalized, params: ["nu", "scale"])),
        Builtin(name: "LKJ",            sig: Distribution(domain: DynMatrix, support: Unknown, mass: Normalized, params: ["n", "eta"])),
        Builtin(name: "LKJCholesky",    sig: Distribution(domain: DynMatrix, support: Unknown, mass: Normalized, params: ["n", "eta"])),

        // ---- base per-name functions (spec §07) ----
        // Per-name signatures expressible via ResultSig: constant scalar output,
        // SameScalarKind, DomainMap, Matrix, and the arg-threading forms
        // SameAsArg / RealOfArgShape / CommonOf / ElemScalarKind. Only ops whose
        // result genuinely cannot be expressed (e.g. operand-promoting elementwise
        // arith add/sub/mul/pow, container shape construction) stay in ops.rs
        // call_rule; prefer a catalogue row whenever ResultSig can carry the rule.

        // -- scalar-integer output --
        // spec §07 "Elementary functions": floor/ceil/round return integers.
        Builtin(name: "floor",    sig: Function(params: [Scalar(Real)],    result: Scalar(Integer))),
        Builtin(name: "ceil",     sig: Function(params: [Scalar(Real)],    result: Scalar(Integer))),
        Builtin(name: "round",    sig: Function(params: [Scalar(Real)],    result: Scalar(Integer))),
        // integer(x): set-restrict to integers (spec §07 "Scalar restrictions").
        Builtin(name: "integer",  sig: Function(params: [Any],             result: Scalar(Integer))),
        // div / mod: integer Euclidean quotient/remainder (spec §07).
        Builtin(name: "div",      sig: Function(params: [Scalar(Integer), Scalar(Integer)], result: Scalar(Integer))),
        Builtin(name: "mod",      sig: Function(params: [Scalar(Integer), Scalar(Integer)], result: Scalar(Integer))),
        // lengthof / length: number of elements in a vector (spec §07 Reductions).
        Builtin(name: "lengthof", sig: Function(params: [Any], result: Scalar(Integer), result_set: NonNegIntegers)),
        Builtin(name: "length",   sig: Function(params: [Any], result: Scalar(Integer), result_set: NonNegIntegers)),

        // -- scalar-real output --
        // NOTE: divide and mean are intentionally NOT here. Their result types
        // are structural, not constant:
        //   - divide(a, b) promotes its two operands (complex if either is) —
        //     stays in ops.rs call_rule via promote2, like pow/min/max.
        //   - mean(xs) reduces to the array element type (complex array →
        //     complex) — stays in ops.rs via reduce_type, like sum/prod.
        // (spec §07: divide over "scalars (real or complex)"; mean over
        // "real/complex arrays".)
        // logdensityof / densityof return a real scalar (spec §07 §06).
        Builtin(name: "logdensityof", sig: Function(params: [Any, Any], result: Scalar(Real))),
        Builtin(name: "densityof",    sig: Function(params: [Any, Any], result: Scalar(Real), result_set: NonNegReals)),
        // Norms (spec §07 "Norms and normalization"): l1/l2 norm → real scalar.
        Builtin(name: "l1norm",       sig: Function(params: [Any],      result: Scalar(Real), result_set: NonNegReals)),
        Builtin(name: "l2norm",       sig: Function(params: [Any],      result: Scalar(Real), result_set: NonNegReals)),
        // logsumexp (spec §07): log Σ exp(v_i) → real.
        Builtin(name: "logsumexp",    sig: Function(params: [Any],      result: Scalar(Real))),
        // var/std (spec §07 "Reductions") involve a division/sqrt → always real.
        Builtin(name: "var",          sig: Function(params: [Any],      result: Scalar(Real), result_set: NonNegReals)),
        Builtin(name: "std",          sig: Function(params: [Any],      result: Scalar(Real), result_set: NonNegReals)),
        // maximum/minimum return an ELEMENT of the array, so the result kind
        // follows the element kind (an integer array yields an integer).
        Builtin(name: "maximum",      sig: Function(params: [Any],      result: ElemScalarKind(0))),
        Builtin(name: "minimum",      sig: Function(params: [Any],      result: ElemScalarKind(0))),
        // logabsdet(A) = log|det A| (spec §07 "Linear algebra"): always real.
        Builtin(name: "logabsdet",    sig: Function(params: [Matrix],   result: Scalar(Real))),

        // -- scalar output threading the argument's element kind --
        // det(A) / trace(A) (spec §07 "Linear algebra"): a real matrix yields a
        // real scalar, a complex matrix a complex scalar — ElemScalarKind drills
        // the matrix element type.
        Builtin(name: "det",          sig: Function(params: [Matrix],   result: ElemScalarKind(0))),
        Builtin(name: "trace",        sig: Function(params: [Matrix],   result: ElemScalarKind(0))),

        // -- result threads the argument's full type / shape (spec §07) --
        // identity(x) returns x unchanged; reverse/cumsum/cumprod preserve the
        // input vector's shape and element type.
        Builtin(name: "identity",     sig: Function(params: [Any],      result: SameAsArg(0))),
        // bijection(f, f_inv, logvolume) annotates f and is semantically f
        // (spec §06) → its type is f's type.
        Builtin(name: "bijection",    sig: Function(params: [Callable, Callable, Any], result: SameAsArg(0))),
        Builtin(name: "reverse",      sig: Function(params: [Any],      result: SameAsArg(0))),
        Builtin(name: "cumsum",       sig: Function(params: [Any],      result: SameAsArg(0))),
        Builtin(name: "cumprod",      sig: Function(params: [Any],      result: SameAsArg(0))),
        // real(x) = Re(x), imag(x) = Im(x): real-valued, shape-preserving (spec §07).
        Builtin(name: "real",         sig: Function(params: [Any],      result: RealOfArgShape(0))),
        Builtin(name: "imag",         sig: Function(params: [Any],      result: RealOfArgShape(0))),
        // ifelse(cond, a, b) returns a or b → the common type of the two branches (spec §07).
        Builtin(name: "ifelse",       sig: Function(params: [Scalar(Boolean), Any, Any], result: CommonOf(1, 2))),

        // -- linear algebra: matrix/vector results (spec §07 "Linear algebra") --
        // Lengths/dims degrade to dynamic (no value-level shape arithmetic in the
        // type system); element kinds are exact.
        // eye(n): real identity matrix.
        Builtin(name: "eye",            sig: Function(params: [Scalar(Integer)], result: Matrix(rows: Dyn, cols: Dyn))),
        // inv / lower_cholesky: square matrix, element kind preserved (a complex
        // matrix inverts to a complex matrix).
        Builtin(name: "inv",            sig: Function(params: [Matrix], result: MatrixElem(rows: Dyn, cols: Dyn, elem: OfArg(0)))),
        Builtin(name: "lower_cholesky", sig: Function(params: [Matrix], result: MatrixElem(rows: Dyn, cols: Dyn, elem: OfArg(0)))),
        // qr(A) → record(Q, R): both matrices with A's element kind (spec §07).
        Builtin(name: "qr", sig: Function(params: [Matrix], result: Record([
            ("Q", MatrixElem(rows: Dyn, cols: Dyn, elem: OfArg(0))),
            ("R", MatrixElem(rows: Dyn, cols: Dyn, elem: OfArg(0))),
        ]))),
        // diagmat(x): vector → diagonal matrix, element kind from the vector.
        Builtin(name: "diagmat",        sig: Function(params: [Vector(Real)], result: MatrixElem(rows: Dyn, cols: Dyn, elem: OfArg(0)))),
        // diag(A, k=0): extract a diagonal as a vector, element kind from A.
        Builtin(name: "diag",           sig: Function(params: [Matrix, Scalar(Integer)], result: Vector(len: Dyn, elem: OfArg(0)))),
        // cross(a, b): 3-vector cross product, element kind from a.
        Builtin(name: "cross",          sig: Function(params: [Vector(Real), Vector(Real)], result: Vector(len: Dyn, elem: OfArg(0)))),
        // linspace / extlinspace: real vector of grid points.
        Builtin(name: "linspace",       sig: Function(params: [Scalar(Real), Scalar(Real), Scalar(Integer)], result: Vector(len: Dyn, elem: Real))),
        Builtin(name: "extlinspace",    sig: Function(params: [Scalar(Real), Scalar(Real), Scalar(Integer)], result: Vector(len: Dyn, elem: Real))),
        // sizeof(x): the dimensions of x as an integer vector.
        Builtin(name: "sizeof",         sig: Function(params: [Any], result: Vector(len: Dyn, elem: Integer))),
        // totalmass(M): total mass Z = ∫ dM as a real scalar (spec §06).
        Builtin(name: "totalmass",      sig: Function(params: [Any], result: Scalar(Real), result_set: NonNegReals)),

        // -- more linear algebra / vector constructors (spec §07) --
        // boolean(x): set-restrict to booleans → boolean scalar.
        Builtin(name: "boolean",        sig: Function(params: [Any], result: Scalar(Boolean))),
        // quadform(A, x) = xᵀ A x → scalar, element kind from A.
        Builtin(name: "quadform",       sig: Function(params: [Matrix, Vector(Real)], result: ElemScalarKind(0))),
        // Gram / outer products → matrix, element kind preserved.
        Builtin(name: "row_gram",       sig: Function(params: [Matrix], result: MatrixElem(rows: Dyn, cols: Dyn, elem: OfArg(0)))),
        Builtin(name: "col_gram",       sig: Function(params: [Matrix], result: MatrixElem(rows: Dyn, cols: Dyn, elem: OfArg(0)))),
        Builtin(name: "self_outer",     sig: Function(params: [Vector(Real)], result: MatrixElem(rows: Dyn, cols: Dyn, elem: OfArg(0)))),
        // Block / banded / stacked matrix constructors → matrix, element kind
        // drilled from the (nested) argument.
        Builtin(name: "blockdiagmat",   sig: Function(params: [Any], result: MatrixElem(rows: Dyn, cols: Dyn, elem: OfArg(0)))),
        Builtin(name: "bandedmat",      sig: Function(params: [Vector(Real), Scalar(Integer)], result: MatrixElem(rows: Dyn, cols: Dyn, elem: OfArg(0)))),
        Builtin(name: "joinblocks",     sig: Function(params: [Any], result: MatrixElem(rows: Dyn, cols: Dyn, elem: OfArg(0)))),
        Builtin(name: "colstack",       sig: Function(params: [Any], result: MatrixElem(rows: Dyn, cols: Dyn, elem: OfArg(0)))),
        // onehot(i, n): real basis vector.
        Builtin(name: "onehot",         sig: Function(params: [Scalar(Integer), Scalar(Integer)], result: Vector(len: Dyn, elem: Real))),
        // conv / crosscorr: 1-D vector result, element kind from the signal.
        Builtin(name: "conv",           sig: Function(params: [Vector(Real), Vector(Real)], result: Vector(len: Dyn, elem: OfArg(0)))),
        Builtin(name: "crosscorr",      sig: Function(params: [Vector(Real), Vector(Real)], result: Vector(len: Dyn, elem: OfArg(0)))),
        // bincounts(bins, data): integer counts per bin.
        Builtin(name: "bincounts",      sig: Function(params: [Any, Any], result: Vector(len: Dyn, elem: Integer))),
        // transpose / adjoint: rank- and element-preserving (a matrix's dims
        // swap; a vector's transpose stays a rank-1 transposed vector, spec §07).
        Builtin(name: "transpose",      sig: Function(params: [Any], result: TransposeOf(0))),
        Builtin(name: "adjoint",        sig: Function(params: [Any], result: TransposeOf(0))),
        // linsolve(A, b): solve Ax = b → x has the same shape/type as b.
        Builtin(name: "linsolve",       sig: Function(params: [Matrix, Vector(Real)], result: SameAsArg(1))),
        // Polynomial / basis evaluations at x → real-valued, shaped like x
        // (scalar x → scalar, array x → array).
        Builtin(name: "polynomial",     sig: Function(params: [Vector(Real), Any], result: RealOfArgShape(1))),
        Builtin(name: "bernstein",      sig: Function(params: [Vector(Real), Any], result: RealOfArgShape(1))),
        Builtin(name: "stepwise",       sig: Function(params: [Vector(Real), Vector(Real), Any], result: RealOfArgShape(2))),

        // -- scalar-complex output --
        // cis(theta) = exp(i*theta); complex(re, im) = re + i*im (spec §07).
        Builtin(name: "cis",     sig: Function(params: [Scalar(Real)],               result: Scalar(Complex))),
        Builtin(name: "complex", sig: Function(params: [Scalar(Real), Scalar(Real)], result: Scalar(Complex))),

        // -- scalar-boolean output --
        // Comparison operators (spec §07 "Operator-equivalent functions").
        Builtin(name: "equal",    sig: Function(params: [Any, Any], result: Scalar(Boolean))),
        Builtin(name: "unequal",  sig: Function(params: [Any, Any], result: Scalar(Boolean))),
        Builtin(name: "lt",       sig: Function(params: [Any, Any], result: Scalar(Boolean))),
        Builtin(name: "le",       sig: Function(params: [Any, Any], result: Scalar(Boolean))),
        Builtin(name: "gt",       sig: Function(params: [Any, Any], result: Scalar(Boolean))),
        Builtin(name: "ge",       sig: Function(params: [Any, Any], result: Scalar(Boolean))),
        // Membership test (spec §07).
        Builtin(name: "in",       sig: Function(params: [Any, Any], result: Scalar(Boolean))),
        // Logical operators (spec §07 "Logic and conditionals").
        Builtin(name: "land",     sig: Function(params: [Scalar(Boolean), Scalar(Boolean)], result: Scalar(Boolean))),
        Builtin(name: "lor",      sig: Function(params: [Scalar(Boolean), Scalar(Boolean)], result: Scalar(Boolean))),
        Builtin(name: "lnot",     sig: Function(params: [Scalar(Boolean)],                  result: Scalar(Boolean))),
        Builtin(name: "lxor",     sig: Function(params: [Scalar(Boolean), Scalar(Boolean)], result: Scalar(Boolean))),
        // Scalar predicates (spec §07).
        Builtin(name: "isfinite", sig: Function(params: [Any], result: Scalar(Boolean))),
        Builtin(name: "isinf",    sig: Function(params: [Any], result: Scalar(Boolean))),
        Builtin(name: "isnan",    sig: Function(params: [Any], result: Scalar(Boolean))),
        Builtin(name: "iszero",   sig: Function(params: [Any], result: Scalar(Boolean))),

        // -- SameScalarKind(0): real→real, complex→complex --
        // (spec §07 "Elementary functions": all accept reals and complexes)
        Builtin(name: "exp",       sig: Function(params: [Any], result: SameScalarKind(0), result_set: PosReals)),
        Builtin(name: "log",       sig: Function(params: [Any], result: SameScalarKind(0))),
        // log2: in ops.rs but absent from spec §07. Kept for engine compatibility.
        Builtin(name: "log2",      sig: Function(params: [Any], result: SameScalarKind(0)),
            degraded: Some("log2 is not listed in spec §07; kept for engine compatibility")),
        Builtin(name: "log10",     sig: Function(params: [Any], result: SameScalarKind(0))),
        Builtin(name: "sqrt",      sig: Function(params: [Any], result: SameScalarKind(0), result_set: NonNegReals)),
        Builtin(name: "sin",       sig: Function(params: [Any], result: SameScalarKind(0), result_set: Interval(-1.0, 1.0))),
        Builtin(name: "cos",       sig: Function(params: [Any], result: SameScalarKind(0), result_set: Interval(-1.0, 1.0))),
        Builtin(name: "tan",       sig: Function(params: [Any], result: SameScalarKind(0))),
        Builtin(name: "asin",      sig: Function(params: [Any], result: SameScalarKind(0))),
        Builtin(name: "acos",      sig: Function(params: [Any], result: SameScalarKind(0))),
        Builtin(name: "atan",      sig: Function(params: [Any], result: SameScalarKind(0))),
        Builtin(name: "sinh",      sig: Function(params: [Any], result: SameScalarKind(0))),
        Builtin(name: "cosh",      sig: Function(params: [Any], result: SameScalarKind(0), result_set: PosReals)),
        Builtin(name: "tanh",      sig: Function(params: [Any], result: SameScalarKind(0), result_set: Interval(-1.0, 1.0))),
        Builtin(name: "asinh",     sig: Function(params: [Any], result: SameScalarKind(0))),
        Builtin(name: "acosh",     sig: Function(params: [Any], result: SameScalarKind(0))),
        Builtin(name: "atanh",     sig: Function(params: [Any], result: SameScalarKind(0))),
        Builtin(name: "log1p",     sig: Function(params: [Any], result: SameScalarKind(0))),
        Builtin(name: "expm1",     sig: Function(params: [Any], result: SameScalarKind(0))),
        Builtin(name: "gamma",     sig: Function(params: [Any], result: SameScalarKind(0))),
        Builtin(name: "loggamma",  sig: Function(params: [Any], result: SameScalarKind(0))),
        Builtin(name: "logit",     sig: Function(params: [Any], result: SameScalarKind(0))),
        Builtin(name: "invlogit",  sig: Function(params: [Any], result: SameScalarKind(0), result_set: UnitInterval)),
        Builtin(name: "probit",    sig: Function(params: [Any], result: SameScalarKind(0))),
        Builtin(name: "invprobit", sig: Function(params: [Any], result: SameScalarKind(0), result_set: UnitInterval)),
        // abs / abs2: |x| and |x|² are real for both real and complex inputs
        // (real_or_complex(arg) in ops.rs: complex→real, not complex→complex).
        // DomainMap captures this: Complex maps to Real; anything else defaults Real.
        Builtin(name: "abs",  sig: Function(params: [Any], result: DomainMap(arg: 0, map: [(Complex, Real)]), result_set: NonNegReals)),
        Builtin(name: "abs2", sig: Function(params: [Any], result: DomainMap(arg: 0, map: [(Complex, Real)]), result_set: NonNegReals)),
        // conj: complex conjugate — real→real, complex→complex.
        Builtin(name: "conj", sig: Function(params: [Any], result: SameScalarKind(0))),
    ],
    // Standard modules (spec §09) live in their own RON files under
    // catalogues/ and are merged in by catalogue::builtin().
    modules: [],
)
