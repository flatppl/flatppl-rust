# Common definitions for some Bayesian inference examples

priors = load_module("bayesian_inference_priors.flatppl")
# Prior distributions
theta1_dist = priors.theta1_dist
theta2_dist = priors.theta2_dist

# Deterministic functions
c = external(reals)    % Scaling factor
f_a = par -> c * par    % Scale by c
f_b = fn(abs(_) * _)    % abs(arg1) * arg2
