flatppl_compat = "0.1"
# bi2 expresses the model with stochastic `~` bindings, so its
# `prior = lawof(record(theta1 = theta1, theta2 = theta2))` is a lawof over a
# record of draws. `posterior = bayesupdate(L, prior)` lowers to
# log-likelihood + log-prior once the lawof-wrapped prior is unwrapped.
m = load_module("../bayesian_inference/bayesian_inference_2.flatppl")
lp = logdensityof(m.posterior, record(theta1 = 0.5, theta2 = 1.0))
