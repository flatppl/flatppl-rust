flatppl_compat = "0.1"
# bi4 conditions the joint law on the observed data with
# `posterior = restrict(joint_model, record(obs = observed_data))` (§06 "Measure
# restriction"). Determinizing desugars `restrict(M, x)` into
# `bayesupdate(likelihoodof(kernel, x), marginal)` over the disintegration on x's
# fields, giving the SAME log-posterior as bi1/bi2/bi3 (same model).
m = load_module("../bayesian_inference/bayesian_inference_4.flatppl")
lp = logdensityof(m.posterior, record(theta1 = 0.5, theta2 = 1.0))
